      "implements",
      "mitigates",
      "attributed-to",
      "variant-of",
      "compromises",
      "downloads",
      "delivers"
    ],
    "matching_rules": [
      {
        "source": "intrusion-set",
        "target": "attack-pattern",
        "relationship": "uses"
      },
      {
        "source": "malware",
        "target": "vulnerability",
        "relationship": "exploits"
      },
      {
        "source": "intrusion-set",
        "target": "location",
        "relationship": "targets"
      },
      {
        "source": "indicator",
        "target": "malware",
        "relationship": "indicates"
      },
      {
        "source": "intrusion-set",
        "target": "campaign",
        "relationship": "launches"
